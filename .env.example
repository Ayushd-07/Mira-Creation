# ============================================================================
# Mira Creation ERP - Environment Variables Example
# Copy this file to `server/.env` for local development, and set the same
# variables in the Vercel project dashboard for production.
# NEVER commit a real .env file or real secrets.
# ============================================================================

# ---- Server ----
# Port used by the local dev server (ignored on Vercel).
PORT=4000
# Set to "production" on Vercel (Vercel sets NODE_ENV automatically too).
NODE_ENV=development

# ---- Database (REQUIRED: PostgreSQL) ----
# Vercel has no persistent local database, so you MUST use a hosted
# PostgreSQL database (Neon, Supabase, Railway, AWS RDS, etc.).
# Example: postgresql://USER:PASSWORD@HOST:5432/mira_creation
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/mira_creation"

# ---- JWT Authentication ----
# Use a long, random, unique secret in production (min 32 characters).
JWT_SECRET="your-super-secret-jwt-key-change-in-production"
JWT_EXPIRES_IN="7d"

# ---- Frontend URL(s) for CORS ----
# Comma-separate multiple origins if needed (e.g. preview + production).
# Local dev:  http://localhost:5173
# Production: https://your-app.vercel.app
FRONTEND_URL=http://localhost:5173

# ---- File / Logo Storage ----
# On Vercel, use Vercel Blob for persistent logo storage (the local
# filesystem is ephemeral and resets on every deploy).
# Create a Blob store in the Vercel dashboard; BLOB_READ_WRITE_TOKEN is
# then injected automatically. When this token is present, logos are stored
# in Blob and served via absolute URLs. When absent, the server falls back
# to local disk (development only).
BLOB_READ_WRITE_TOKEN=

# ---- Supabase (REQUIRED for Frontend Direct Connection) ----
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=